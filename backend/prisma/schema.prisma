generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  PATIENT
  ASHA
  DOCTOR
}

enum AppointmentStatus {
  PENDING
  BOOKED
  COMPLETED
  CANCELLED
}

enum EscalationStatus {
  OPEN
  RESOLVED
}

model User {
  id           String          @id @default(cuid())
  fullName     String
  email        String          @unique
  passwordHash String
  role         Role
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  patient      PatientProfile?
  asha         AshaProfile?
  doctor       DoctorProfile?
}

model PatientProfile {
  id               String           @id @default(cuid())
  userId           String           @unique
  age              Int
  gender           String
  village          String
  ashaWorkerId     String?
  createdAt        DateTime         @default(now())
  user             User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  ashaWorker       AshaProfile?     @relation("AssignedPatients", fields: [ashaWorkerId], references: [id])
  appointments     Appointment[]
  healthRecords    HealthRecord[]
  homeVisits       HomeVisit[]
  escalations      Escalation[]
  prescriptions    Prescription[]
  symptomChecks    SymptomCheck[]
}

model AshaProfile {
  id               String           @id @default(cuid())
  userId           String           @unique
  region           String
  createdAt        DateTime         @default(now())
  user             User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  assignedPatients PatientProfile[] @relation("AssignedPatients")
  homeVisits       HomeVisit[]
  escalations      Escalation[]
}

model DoctorProfile {
  id             String         @id @default(cuid())
  userId         String         @unique
  specialization String
  createdAt      DateTime       @default(now())
  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  appointments   Appointment[]
  escalations    Escalation[]
  prescriptions  Prescription[]
}

model Appointment {
  id          String            @id @default(cuid())
  patientId   String
  doctorId    String
  scheduledAt DateTime
  notes       String?
  status      AppointmentStatus @default(BOOKED)
  createdAt   DateTime          @default(now())
  patient     PatientProfile    @relation(fields: [patientId], references: [id], onDelete: Cascade)
  doctor      DoctorProfile     @relation(fields: [doctorId], references: [id], onDelete: Cascade)
}

model HealthRecord {
  id          String         @id @default(cuid())
  patientId   String
  title       String
  description String
  createdAt   DateTime       @default(now())
  patient     PatientProfile @relation(fields: [patientId], references: [id], onDelete: Cascade)
}

model HomeVisit {
  id            String         @id @default(cuid())
  patientId     String
  ashaWorkerId  String
  visitDate     DateTime
  notes         String
  bloodPressure String
  heartRate     Int
  temperature   Float
  createdAt     DateTime       @default(now())
  patient       PatientProfile @relation(fields: [patientId], references: [id], onDelete: Cascade)
  ashaWorker    AshaProfile    @relation(fields: [ashaWorkerId], references: [id], onDelete: Cascade)
}

model Escalation {
  id            String           @id @default(cuid())
  patientId      String
  ashaWorkerId   String
  doctorId       String
  reason         String
  status         EscalationStatus @default(OPEN)
  resolvedNotes  String?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  patient        PatientProfile   @relation(fields: [patientId], references: [id], onDelete: Cascade)
  ashaWorker     AshaProfile      @relation(fields: [ashaWorkerId], references: [id], onDelete: Cascade)
  doctor         DoctorProfile    @relation(fields: [doctorId], references: [id], onDelete: Cascade)
}

model Prescription {
  id          String         @id @default(cuid())
  patientId   String
  doctorId    String
  medication  String
  dosage      String
  notes       String?
  createdAt   DateTime       @default(now())
  patient     PatientProfile @relation(fields: [patientId], references: [id], onDelete: Cascade)
  doctor      DoctorProfile  @relation(fields: [doctorId], references: [id], onDelete: Cascade)
}

model SymptomCheck {
  id          String         @id @default(cuid())
  patientId   String
  symptoms    String
  severity    String
  duration    String
  createdAt   DateTime       @default(now())
  patient     PatientProfile @relation(fields: [patientId], references: [id], onDelete: Cascade)
}
